{
    "day1_after_start": {
        "name": "",
        "text": ""
    },
    "day1_after_choice": {
        "name": "나",
        "text": "*방과후, 어디로 갈까?*",
        "choices": [
            "세아가 학생회실에 놀러 오라고 했다",
            "도서관에서 유나를 다시 만나본다",
            "보건실의 리인 선생님이 왠지 신경 쓰인다",
            "교무실에서 은수 선생님께 인사드린다",
            "오늘은 이만 집으로"
        ]
    },

    "day1_after_sea_1": {
        "name": "",
        "text": "*작은 방. 책상 두 개, 사물함, 창가에 화분. 정돈되어 있다.*"
    },
    "day1_after_sea_2": {
        "name": "한세아",
        "text": "\"와줬네. 여기 학생회실이야.\""
    },
    "day1_after_sea_3": {
        "name": "",
        "text": "*캔 음료를 건넨다. 자연스럽다.*"
    },
    "day1_after_sea_4": {
        "name": "한세아",
        "text": "\"어때, 살 만해?\""
    },
    "day1_after_sea_5": {
        "name": "나",
        "text": "\"생각보다 괜찮다. 세아가 많이 챙겨줘서.\""
    },
    "day1_after_sea_6": {
        "name": "한세아",
        "text": "\"...그래?\""
    },
    "day1_after_sea_7": {
        "name": "",
        "text": "*세아가 살짝 숨을 내쉬며 웃는다.*"
    },
    "day1_after_sea_8": {
        "name": "한세아",
        "text": "\"첫날이 제일 힘든 거거든. 아무도 모르니까.\""
    },
    "day1_after_sea_9": {
        "name": "",
        "text": "*세아가 창밖을 본다. 노을빛이 들어온다.*"
    },
    "day1_after_sea_10": {
        "name": "한세아",
        "text": "\"...{name}이 와줘서 기쁘다. 학생회실에 혼자 있으면 좀 심심하거든.\""
    },
    "day1_after_sea_11": {
        "name": "나",
        "text": "\"다른 학생회 멤버는?\""
    },
    "day1_after_sea_12": {
        "name": "한세아",
        "text": "\"있긴 한데... 방과후에 여기까지 오는 건 나뿐이야.\""
    },
    "day1_after_sea_13": {
        "name": "한세아",
        "text": "\"...내일도 올래?\""
    },
    "day1_after_sea_14": {
        "name": "나",
        "text": "\"응, 시간 되면.\""
    },
    "day1_after_sea_15": {
        "name": "한세아",
        "text": "\"나 진짜 기다린다? 안 오면 교실로 쳐들어간다.\""
    },
    "day1_after_sea_16": {
        "name": "",
        "text": "*세아가 눈을 마주치며 확인한다. 거절할 수가 없다.*"
    },

    "day1_after_yuna_1": {
        "name": "",
        "text": "*유나가 창가 자리에서 사진을 정리하고 있다.*"
    },
    "day1_after_yuna_2": {
        "name": "최유나",
        "text": "\"선배! 또 왔어요?\""
    },
    "day1_after_yuna_3": {
        "name": "",
        "text": "*유나가 카메라를 넘기며 사진을 보여준다. 학교 풍경, 벚꽃, 고양이.*"
    },
    "day1_after_yuna_4": {
        "name": "최유나",
        "text": "\"이 고양이 치즈예요. 제가 이름 지었어요.\""
    },
    "day1_after_yuna_5": {
        "name": "",
        "text": "*고양이 이야기로 한참 수다를 떨었다. 유나가 눈을 반짝이며 계속 얘기한다.*"
    },
    "day1_after_yuna_6": {
        "name": "최유나",
        "text": "\"선배... 내일도 도서관 오실 거죠?\""
    },
    "day1_after_yuna_7": {
        "name": "나",
        "text": "\"응, 시간 되면.\""
    },
    "day1_after_yuna_8": {
        "name": "최유나",
        "text": "\"...꼭 오세요.\""
    },
    "day1_after_yuna_9": {
        "name": "",
        "text": "*'꼭'에 힘이 들어가 있었다. ...왜 그렇게 진지하지?*"
    },

    "day1_after_riin_1": {
        "name": "",
        "text": "*리인 선생님과 허브차를 마셨다. 편안한 시간.*"
    },
    "day1_after_riin_2": {
        "name": "강리인",
        "text": "\"전학하면 환경이 확 바뀌잖아. 잠을 잘 못 자거나, 이상한 꿈 꾸는 애들이 꽤 있거든.\""
    },
    "day1_after_riin_3": {
        "name": "나",
        "text": "\"아직은 괜찮아요.\""
    },
    "day1_after_riin_4": {
        "name": "강리인",
        "text": "\"그래? 다행이다.\""
    },
    "day1_after_riin_5": {
        "name": "",
        "text": "*리인 선생님이 웃으며 문을 열어준다.*"
    },

    "day1_after_eunsu_1": {
        "name": "박은수",
        "text": "\"{name}? 방과후에 직접 와줬어? 고마워.\""
    },
    "day1_after_eunsu_2": {
        "name": "",
        "text": "*커피를 내려주며 이것저것 물어본다.*"
    },
    "day1_after_eunsu_3": {
        "name": "박은수",
        "text": "\"...{name}, 혹시 이전 학교에서 무슨 일 있었어? 전학 사유가 좀 특이해서...\""
    },
    "day1_after_eunsu_4": {
        "name": "나",
        "text": "\"특이하다고요? 그냥 부모님 이사 때문인데...\""
    },
    "day1_after_eunsu_5": {
        "name": "박은수",
        "text": "\"아, 아니야. 별 뜻 없어.\""
    },
    "day1_after_eunsu_6": {
        "name": "",
        "text": "*선생님이 화제를 돌렸다.*"
    },

    "day1_after_home_1": {
        "name": "",
        "text": "*교문을 나서면서 뒤를 돌아본다.*"
    },
    "day1_after_home_2": {
        "name": "나",
        "text": "*첫날치고 괜찮았어.*"
    },
    "day1_after_home_3": {
        "name": "",
        "text": "*...학교 3층 창가에서 누군가 나를 내려다보고 있다.*"
    },
    "day1_after_home_4": {
        "name": "",
        "text": "*역광이라 얼굴은 안 보인다. 실루엣만. ...뒷자리 창가 쪽. 설화의 자리 근처.*"
    },
    "day1_after_home_5": {
        "name": "",
        "text": "*손을 흔들어봤다. 반응은 없다.*"
    },
    "day1_after_home_6": {
        "name": "",
        "text": "*돌아서서 걷는다. 집에 가자.*"
    },

    "day1_after_end": {
        "name": "",
        "text": ""
    }
}
