{
    "day1_lunch_start": {
        "name": "나",
        "text": "*점심시간. 배고프다. 학식이 어딘지도 모르겠고.*"
    },
    "day1_lunch_start_2": {
        "name": "나",
        "text": "*어디서 먹지.*"
    },
    "day1_lunch_choice": {
        "name": "나",
        "text": "*점심시간, 어디로 갈까?*",
        "choices": [
            "세아가 같이 먹자고 했으니 교실에 남는다",
            "조용한 도서관에 가본다",
            "아까부터 머리가 좀 아프다... 보건실에 가볼까",
            "혼자 옥상에서 먹는다"
        ]
    },
    "day1_lunch_sea": {
        "name": "한세아",
        "text": "\"어디 가? 같이 먹으려고 기다리고 있었는데. 자리 잡아놨어.\""
    },
    "day1_lunch_sea_2": {
        "name": "나",
        "text": "*세아가 도시락을 펼친다. 양이 많다.*"
    },
    "day1_lunch_sea_3": {
        "name": "한세아",
        "text": "\"좀 많이 가져왔는데, 입맛에 맞을지 모르겠다.\""
    },
    "day1_lunch_sea_4": {
        "name": "나",
        "text": "*고등어조림에 계란말이에 시금치나물. 집밥 느낌이라 맛있다.*"
    },
    "day1_lunch_sea_5": {
        "name": "한세아",
        "text": "\"...괜찮아? 내일도 가져올까?\""
    },
    "day1_lunch_sea_6": {
        "name": "나",
        "text": "\"이거 진짜 맛있다. 직접 만든 거야?\""
    },
    "day1_lunch_yuna_start": {
        "name": "나",
        "text": "*도서관에 들어섰다. 점심시간이라 사람이 거의 없다.*"
    },
    "day1_lunch_yuna_1": {
        "name": "나",
        "text": "*책장 사이를 걷는데, 구석에서 '찰칵' 소리가 들린다.*"
    },
    "day1_lunch_yuna_2": {
        "name": "???",
        "text": "\"...!\""
    },
    "day1_lunch_yuna_3": {
        "name": "나",
        "text": "*카메라를 든 여학생이 당황한 표정으로 굳어 있다.*"
    },
    "day1_lunch_yuna_4": {
        "name": "나",
        "text": "\"사진부?\""
    },
    "day1_lunch_yuna_5": {
        "name": "최유나",
        "text": "\"아, 아니에요...! 사진부라서, 도서관 분위기 찍고 있었는데 갑자기 들어오셔서... 1학년 최유나예요. 전학 온 선배 맞죠?\""
    },
    "day1_lunch_yuna_6": {
        "name": "나",
        "text": "*다급하게 손을 내젓는다. 표정은 당황스러워 보이면서도, 눈은 어딘가 안도한 것처럼.*"
    },
    "day1_lunch_nurse_start": {
        "name": "나",
        "text": "*보건실 문을 연다. 소독약 냄새.*"
    },
    "day1_lunch_riin_1": {
        "name": "보건교사",
        "text": "\"첫날부터 보건실이야? 어디 불편해?\""
    },
    "day1_lunch_riin_2": {
        "name": "나",
        "text": "\"머리가 좀 아파서요. 두통약 있을까요?\""
    },
    "day1_lunch_riin_3": {
        "name": "보건교사",
        "text": "\"앉아봐. 먼저 좀 볼게.\""
    },
    "day1_lunch_riin_4": {
        "name": "나",
        "text": "*간단히 진찰을 받았다. 보건실이 깔끔하고 조용하다.*"
    },
    "day1_lunch_riin_5": {
        "name": "보건교사",
        "text": "\"여기. 졸리면 좀 쉬다 가도 돼.\""
    },
    "day1_lunch_alone": {
        "name": "나",
        "text": "*옥상이다. 바람이 좋다.*"
    },
    "day1_lunch_alone_2": {
        "name": "나",
        "text": "*도시락 먹으면서 운동장을 내려다본다. 평화롭다.*"
    },
    "day1_lunch_alone_3": {
        "name": "나",
        "text": "*혼자만의 시간도 나쁘지 않다.*"
    },
    "day1_lunch_end": {
        "name": "나",
        "text": "*점심시간이 끝났다. 오후 수업 가자.*"
    }
}
