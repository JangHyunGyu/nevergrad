{
    "day1_opening": {
        "name": "나",
        "text": "*벚꽃이 흩날린다. 따스한 봄바람이 교복 사이로 스며든다. 오늘부터 이 학교 학생이다.*"
    },
    "day1_opening_2": {
        "name": "나",
        "text": "*새 학교 교문 앞. 살짝 긴장되지만, 나쁘지 않은 떨림이다.*"
    },
    "day1_opening_3": {
        "name": "나",
        "text": "*자, 들어가자.*"
    },

    "day1_hallway_1": {
        "name": "나",
        "text": "*복도가 넓다. 교실이 어디지... 안내판을 찾아보는데.*"
    },
    "day1_sea_first": {
        "name": "???",
        "text": "\"혹시 전학생? 오늘 온다고 들었는데.\""
    },
    "day1_sea_first_2": {
        "name": "나",
        "text": "*돌아보니 단정한 인상의 여학생이 서 있다. 자연스럽게 웃고 있지만, 어딘가 준비된 듯한 미소.*"
    },
    "day1_sea_first_3": {
        "name": "한세아",
        "text": "\"한세아야. 이 반 반장. {name} 맞지?\""
    },
    "day1_sea_first_4": {
        "name": "나",
        "text": "\"...내 이름 어떻게 알아?\""
    },
    "day1_sea_choco": {
        "name": "한세아",
        "text": "\"아 맞다, 이거. 초코우유 마시지?\""
    },
    "day1_sea_choco_2": {
        "name": "나",
        "text": "*초코우유를 건넨다. ...좋아한다고 말한 적 없는데.*"
    },
    "day1_sea_choco_choice": {
        "name": "나",
        "text": "*받을까?*",
        "choices": [
            "\"고마워, 잘 마실게.\"",
            "\"...내가 이거 좋아하는 걸 어떻게 알아?\"",
            "\"나 사실 딸기우유가 더 좋긴 한데.\""
        ]
    },
    "day1_sea_choco_accept": {
        "name": "한세아",
        "text": "\"맞지? 왠지 그럴 것 같았어.\""
    },
    "day1_sea_choco_question": {
        "name": "한세아",
        "text": "\"...그냥 느낌? 대부분 좋아하니까.\""
    },
    "day1_sea_choco_question_2": {
        "name": "나",
        "text": "*순간 눈빛이 흔들린 것 같다. ...아닌가.*"
    },
    "day1_sea_choco_joke": {
        "name": "한세아",
        "text": "\"아 진짜? 다음엔 딸기로 가져올게.\""
    },

    "day1_classroom_enter": {
        "name": "나",
        "text": "*세아를 따라 교실에 들어선다. 시선이 모인다.*"
    },
    "day1_classroom_enter_2": {
        "name": "나",
        "text": "*전학생이니까 당연한 거다. 손 좀 흔들어볼까.*"
    },
    "day1_classroom_enter_3": {
        "name": "나",
        "text": "*분위기는 나쁘지 않다. 다들 호기심 반 환영 반인 표정.*"
    },

    "day1_eunsu_enter": {
        "name": "나",
        "text": "*교실 문이 열리고, 담임선생님이 들어온다.*"
    },
    "day1_eunsu_first": {
        "name": "담임교사",
        "text": "\"자, 여러분. 오늘 새로 전학 온 학생이 있어요.\""
    },
    "day1_eunsu_first_2": {
        "name": "담임교사",
        "text": "\"{name} 학생, 앞에 나와서 간단히 인사해줄래요?\""
    },
    "day1_eunsu_first_3": {
        "name": "나",
        "text": "*칠판 앞에 선다. 긴장되지만 뭐, 전학이 처음도 아니고.*"
    },
    "day1_eunsu_first_4": {
        "name": "담임교사",
        "text": "\"...드디어 왔구나.\""
    },
    "day1_eunsu_first_5": {
        "name": "나",
        "text": "\"...네?\""
    },
    "day1_eunsu_first_6": {
        "name": "담임교사",
        "text": "\"아, 전학 온다는 얘기 듣고 기다리고 있었거든요. 자, 자기소개 해볼까요?\""
    },
    "day1_eunsu_first_7": {
        "name": "나",
        "text": "*간단히 인사를 했다. 반응이 좋다. 다행이다.*"
    },

    "day1_seat_guide": {
        "name": "담임교사",
        "text": "\"자리는 저기 창가 뒷줄이에요. 편하게 앉으세요.\""
    },
    "day1_seolhwa_notice": {
        "name": "나",
        "text": "*자리에 앉았다. 창가라 햇빛이 좋다.*"
    },
    "day1_seolhwa_notice_2": {
        "name": "나",
        "text": "*...뒷자리에 누가 앉아 있다. 창백한 피부에, 어딘가 먼 곳을 보는 눈.*"
    },
    "day1_seolhwa_notice_3": {
        "name": "나",
        "text": "*인사할까.*"
    },
    "day1_seolhwa_greet_choice": {
        "name": "나",
        "text": "*뒤를 돌아볼까?*",
        "choices": [
            "\"안녕, 나 {name}이야. 뒤에 앉게 됐네.\"",
            "(지금은 수업에 집중하자)"
        ]
    },
    "day1_seolhwa_greet": {
        "name": "나",
        "text": "\"안녕, 나 {name}이야. 잘 부탁해.\""
    },
    "day1_seolhwa_greet_2": {
        "name": "이설화",
        "text": "\".......\""
    },
    "day1_seolhwa_greet_3": {
        "name": "나",
        "text": "*대답이 없다. 눈이 잠깐 마주친 것 같았는데, 바로 시선을 돌렸다. 낯가림이 심한가 보다.*"
    },
    "day1_seolhwa_greet_4": {
        "name": "옆자리 남학생",
        "text": "\"야, 전학생. 뭘 보는 거야?\""
    },
    "day1_seolhwa_greet_5": {
        "name": "나",
        "text": "\"아니, 뒤에 앉은 애한테 인사했는데.\""
    },
    "day1_seolhwa_greet_6": {
        "name": "옆자리 남학생",
        "text": "\"뒤? 거기 빈자린데?\""
    },
    "day1_seolhwa_greet_7": {
        "name": "나",
        "text": "*...뭐?*"
    },
    "day1_seolhwa_greet_8": {
        "name": "나",
        "text": "*다시 뒤를 본다. 아까 그 여학생이 분명히 있다.*"
    },
    "day1_seolhwa_greet_9": {
        "name": "나",
        "text": "*...장난치는 건가? 전학생 놀리기? 뭐, 그런 거겠지.*"
    },
    "day1_seolhwa_greet_10": {
        "name": "나",
        "text": "*넘기자. 첫날인데 괜히 시비 걸릴 필요 없다.*"
    },
    "day1_seolhwa_skip": {
        "name": "나",
        "text": "*수업에 집중하자.*"
    },
    "day1_morning_end": {
        "name": "나",
        "text": "*이윽고 오전 수업이 끝났다. 쉬는 시간이다.*"
    }
}
