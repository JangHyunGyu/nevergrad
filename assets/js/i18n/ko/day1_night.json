{
    "day1_night_start": {
        "name": "나",
        "text": "*집에 돌아왔다. 라면을 끓여 먹으면서 오늘 하루를 되짚어본다.*"
    },
    "day1_night_home_2": {
        "name": "나",
        "text": "*오늘 만난 사람들이 떠오른다...*"
    },
    "day1_night_home_3": {
        "name": "나",
        "text": "*다 괜찮은 사람들이었다.*"
    },

    "day1_night_phone_1": {
        "name": "나",
        "text": "*폰을 확인한다.*"
    },
    "day1_night_phone_2": {
        "name": "나",
        "text": "*전 학교 그룹 채팅방. 오늘 아침에 보낸 '나 전학 갔어, 잘 지내~' 메시지.*"
    },
    "day1_night_phone_3": {
        "name": "나",
        "text": "*...읽은 사람이 없다. 읽음 0.*"
    },
    "day1_night_phone_4": {
        "name": "나",
        "text": "*친한 친구 민수한테도 개인 메시지를 보냈다. '야 민수 나 전학 왔어! 여기 학교 엄청 커' — 아직 답이 없다.*"
    },
    "day1_night_phone_5": {
        "name": "나",
        "text": "*...뭐, 내일이면 올 거야.*"
    },

    "day1_night_phone_6": {
        "name": "나",
        "text": "*대신 세아한테 메시지가 와있다.*"
    },
    "day1_night_sea_1": {
        "name": "한세아",
        "text": "오늘 재밌었어!"
    },
    "day1_night_sea_2": {
        "name": "한세아",
        "text": "내일 도시락 뭐 먹고 싶어?"
    },
    "day1_night_sea_3": {
        "name": "한세아",
        "text": "리퀘스트 받음ㅋㅋ"
    },
    "day1_night_sea_4": {
        "name": "나",
        "text": "*...첫날부터 내일 도시락 메뉴까지 물어보다니.*"
    },

    "day1_night_sea_reply": {
        "name": "나",
        "text": "*뭐라고 답장하지?*",
        "choices": [
            "'음~ 치킨가스 어때?' (구체적으로 답장)",
            "'아무거나 다 잘 먹어ㅋㅋ' (가볍게 답장)",
            "(답장 안 한다)"
        ]
    },
    "day1_night_sea_reply_1": {
        "name": "한세아",
        "text": "오 좋아! 내일 기대해♡"
    },
    "day1_night_sea_reply_2": {
        "name": "한세아",
        "text": "ㅋㅋㅋ 알겠어~ 내일 놀라지 마!"
    },
    "day1_night_sea_reply_3": {
        "name": "나",
        "text": "*...답장은 내일 하자. 피곤하다.*"
    },

    "day1_night_sleep_1": {
        "name": "나",
        "text": "*이불에 누워서 천장을 본다.*"
    },
    "day1_night_sleep_2": {
        "name": "나",
        "text": "*...적응할 수 있을 것 같다. 이 학교.*"
    },
    "day1_night_sleep_3": {
        "name": "나",
        "text": "*눈을 감는다. 피곤하다.*"
    },
    "day1_night_sleep_4": {
        "name": "나",
        "text": "*...잠이 들기 직전, 묘한 감각이 스쳤다. 이 천장의 얼룩 — 뭔가 익숙한 모양인데.*"
    },
    "day1_night_sleep_5": {
        "name": "나",
        "text": "*...자취방 천장은 다 비슷하게 생겼겠지. 눈을 감았다.*"
    },
    "day1_night_end": {
        "name": "",
        "text": "*— 1일차 종료 —*"
    }
}
