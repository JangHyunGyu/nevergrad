    "day5_after_escaped": {
        "name": "나",
        "text": "*학교 밖. 비가 내리고 있다. 처음으로... 학교 밖 공기를 마신다.*"
    },
    "day5_after_escaped_2": {
        "name": "나",
        "text": "*뛰었다. 어디로든. 이 학교에서 최대한 멀리.*"
    },
    "day5_after_escaped_3": {
        "name": "나",
        "text": "*혼자다. 하지만 살아있다.*"
    },
    "day5_after_escaped_solo": {
        "name": "나",
        "text": "*유나를 두고 왔다. ...미안하다.*"
    },
    "day5_after_escaped_branch": {
        "name": "최유나",
        "text": "\"선배... 우리 나왔어요...\""
    },
    "day5_after_escaped_yuna": {
        "name": "나",
        "text": "*유나가 울고 있다. 나도 울고 있다.*"
    },
    "day5_after_escaped_4": {
        "name": "나",
        "text": "*이 증거를 세상에 알려야 한다. 지금 바로.*"
    },
    "day5_after_escaped_choice": {
        "name": "나",
        "text": "*어떻게 할까.*",
        "choices": [
            "경찰에 신고한다",
            "인터넷에 공개한다"
        ]
    },
    "day5_after_police": {
        "name": "나",
        "text": "*경찰에 전화했다. 목소리가 떨리지만 모든 것을 설명했다. 메모리카드와 사진을 증거로 제출했다.*"
    },
    "day5_after_police_2": {
        "name": "나",
        "text": "*경찰이 출동했다. 사이렌 소리가 학교 방향에서 울린다.*"
    },
    "day5_after_expose_online": {
        "name": "나",
        "text": "*편의점 와이파이에 접속했다. 모든 사진과 문서를 업로드한다. SNS, 뉴스 제보, 커뮤니티...*"
    },
    "day5_after_expose_2": {
        "name": "나",
        "text": "*업로드 완료. ...곧 세상이 알게 될 것이다.*"
    },

    "day5_after_captured": {
        "name": "나",
        "text": "*...눈을 떴다. 지하실이다. 형광등이 깜빡인다.*"
    },
    "day5_after_captured_2": {
        "name": "나",
        "text": "*손이 묶여있다. 의자에 앉혀져 있다. ...끝난 건가?*"
    },
    "day5_after_captured_3": {
        "name": "담임교사",
        "text": "\"깨어났구나, {name}. ...도망치려고 했어?\""
    },
    "day5_after_captured_4": {
        "name": "보건교사",
        "text": "\"마지막 처치를 준비할게. 금방 끝나.\""
    },
    "day5_after_captured_5": {
        "name": "나",
        "text": "*...포기할까?*",
        "choices": [
            "저항한다",
            "받아들인다"
        ]
    },
    "day5_after_captured_resist": {
        "name": "나",
        "text": "*의자를 쓰러뜨렸다! 묶인 손으로 일어선다.*"
    },
    "day5_after_captured_resist_2": {
        "name": "이설화",
        "text": "\"...내가 도와줄게.\""
    },
    "day5_after_captured_resist_3": {
        "name": "나",
        "text": "*갑자기 정전이 됐다. 지하실이 어둠에 잠긴다. 혼란 속에서... 출구를 찾았다.*"
    },
    "day5_after_captured_submit": {
        "name": "보건교사",
        "text": "\"착하네. 금방 끝나. 다 잊게 될 거야.\""
    },
    "day5_after_captured_submit_2": {
        "name": "나",
        "text": "*주사바늘이 팔에 닿는 순간. 의식이... 흐려진다...*"
    },

    "day5_after_stayed": {
        "name": "담임교사",
        "text": "\"...잘 생각했어, {name}. 이게 맞는 거야.\""
    },
    "day5_after_stayed_2": {
        "name": "담임교사",
        "text": "\"선생님이 다 지켜줄게. 아무것도 걱정할 필요 없어.\""
    },
    "day5_after_stayed_3": {
        "name": "담임교사",
        "text": "\"...{name}은 선생님 곁에 있으면 돼. 영원히.\""
    },
    "day5_after_stayed_4": {
        "name": "나",
        "text": "*은수 선생님이 웃고 있다. 따뜻한 미소. ...이 미소가 항상 이렇게 무서웠던가.*"
    },

    "day5_after_end": {
        "name": "나",
        "text": "*...*"
    }
}
