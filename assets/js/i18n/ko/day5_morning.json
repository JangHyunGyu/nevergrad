{
    "day5_morning_start": {
        "name": "나",
        "text": "*5일차. 마지막 날. 눈을 떴다.*"
    },
    "day5_morning_start_2": {
        "name": "나",
        "text": "*창밖을 본다. 하늘이 회색이다. 비가 올 것 같다.*"
    },
    "day5_morning_start_3": {
        "name": "나",
        "text": "*...가자. 오늘 안에 끝낸다.*"
    },

    "day5_morning_gate": {
        "name": "나",
        "text": "*학교 정문. 쇠사슬이 감겨있다. 정문 외의 출구는... 전부 막혀있다.*"
    },
    "day5_morning_gate_2": {
        "name": "나",
        "text": "*학생들이 아무 일 없다는 듯 정문을 통과한다. 마치... 보이지 않는 것처럼.*"
    },
    "day5_morning_gate_3": {
        "name": "나",
        "text": "*세 사람이 정문 앞에 나란히 서 있다.*"
    },
    "day5_morning_welcome": {
        "name": "담임교사",
        "text": "\"좋은 아침, {name}. 오늘은 특별한 날이야.\""
    },
    "day5_morning_welcome_2": {
        "name": "한세아",
        "text": "\"{name}. 오늘은 하루 종일 같이 있자.\""
    },
    "day5_morning_welcome_3": {
        "name": "보건교사",
        "text": "\"건강검진 마무리가 남았어. 방과후에 보건실로 와.\""
    },
    "day5_morning_welcome_4": {
        "name": "나",
        "text": "*세 사람의 미소가 겹쳐 보인다. 똑같은 미소. ...사냥꾼의 미소.*"
    },

    "day5_morning_classroom": {
        "name": "나",
        "text": "*교실. 칠판에 글자가 적혀있다.*"
    },
    "day5_morning_classroom_2": {
        "name": "나",
        "text": "*'졸업식'이라고 적혀있다. ...졸업식? 5일째인데?*"
    },
    "day5_morning_classroom_3": {
        "name": "나",
        "text": "*은수 선생님이 교단에 선다.*"
    },
    "day5_morning_class": {
        "name": "담임교사",
        "text": "\"오늘은 특별한 수업이야. '졸업'에 대해서 이야기해볼까.\""
    },
    "day5_morning_class_2": {
        "name": "담임교사",
        "text": "\"졸업이란 한 과정의 끝이야. 과정을 마치면... 새로운 곳으로 가게 되지.\""
    },
    "day5_morning_class_3": {
        "name": "담임교사",
        "text": "\"{name}, 너의 졸업도... 오늘이야.\""
    },
    "day5_morning_class_4": {
        "name": "나",
        "text": "*...교실이 조용하다. 다른 학생들이 전부 나를 보고 있다. 아무도 움직이지 않는다.*"
    },

    "day5_morning_note": {
        "name": "나",
        "text": "*책상 밑에 쪽지가 붙어있다. 유나의 필체.*"
    },
    "day5_morning_note_alt": {
        "name": "나",
        "text": "*수업이 끝났다. 아무도 도와줄 사람이 없다.*"
    },
    "day5_morning_note_2": {
        "name": "나",
        "text": "*'점심때 구관 3층. 탈출로를 찾았어. - 유나'*"
    },

    "day5_morning_end": {
        "name": "나",
        "text": "*오전이 끝났다. 시계가 멈춘 것처럼 느리다.*"
    }
}
