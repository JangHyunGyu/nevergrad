{
    "day5_night_start": {
        "name": "",
        "text": "*...*"
    },
    "day5_night_routing": {
        "name": "",
        "text": ""
    },

    "day5_ending_true_1": {
        "name": "",
        "text": "*은수 선생님의 손이 떨린다. 주사기가 바닥에 떨어졌다.*"
    },
    "day5_ending_true_2": {
        "name": "박은수",
        "text": "\"......\""
    },
    "day5_ending_true_3": {
        "name": "박은수",
        "text": "\"...그래. 13번째도 — 가는 거구나.\""
    },
    "day5_ending_true_4": {
        "name": "",
        "text": "*선생님이 비켜섰다. 눈을 감고.*"
    },
    "day5_ending_true_5": {
        "name": "",
        "text": "*비상구를 지났다. 유나와 함께. 구관 뒤 비상 계단. 새벽 공기가 차갑다. 학교 울타리 너머로 — 도로가 보인다.*"
    },
    "day5_ending_true_6": {
        "name": "",
        "text": "*뒤를 돌아봤다.*"
    },
    "day5_ending_true_7": {
        "name": "",
        "text": "***설화가 비상구 안쪽에 서 있다. 문 밖으로 나오지 못한다.***"
    },
    "day5_ending_true_8": {
        "name": "설화",
        "text": "\"...가.\""
    },
    "day5_ending_true_9": {
        "name": "나",
        "text": "\"설화—\""
    },
    "day5_ending_true_10": {
        "name": "설화",
        "text": "\"**가라니까.**\""
    },
    "day5_ending_true_11": {
        "name": "",
        "text": "*설화가 웃었다. 빛이 흐려지고 있다.*"
    },
    "day5_ending_true_12": {
        "name": "설화",
        "text": "\"6번 동안 기다렸어. 네가 나가는 걸.\""
    },
    "day5_ending_true_13": {
        "name": "설화",
        "text": "\"...나는 1년 전에 끝난 사람이야. ...근데 네가 나가면 그걸로 됐어.\""
    },
    "day5_ending_true_14": {
        "name": "나",
        "text": "\"기억할게. 이설화. 왼손잡이 이설화.\""
    },
    "day5_ending_true_15": {
        "name": "",
        "text": "*설화가 멈췄다. 돌아봤다. — 울고 있었다. 하지만 웃고 있었다.*"
    },
    "day5_ending_true_16": {
        "name": "설화",
        "text": "\"...이름 불러준 거 처음이야. 13번째 만에.\""
    },
    "day5_ending_true_17": {
        "name": "",
        "text": "*설화의 몸이 투명해진다. 빛 입자가 되어 흩어진다.*"
    },
    "day5_ending_true_18": {
        "name": "",
        "text": "*그 빛이 — 내 쪽으로 흘러왔다. 가슴에 스며든다. ...따뜻하다. 이건 환각이 아니라 — 기억이다.*"
    },
    "day5_ending_true_19": {
        "name": "",
        "text": "*순간, 머릿속에 폭포처럼 쏟아진다.*"
    },
    "day5_ending_true_20": {
        "name": "",
        "text": "***7번째의 기억. 설화와 함께 도서관에서 문서를 찾던 밤. 지하실 잠긴 문 앞에서 나눈 약속. 둘이서 울타리를 넘으려던 순간—***"
    },
    "day5_ending_true_21": {
        "name": "",
        "text": "***그리고 그 전의 기억들까지. 1번째, 2번째, 3번째— 12번의 삶이 동시에 들어온다.***"
    },
    "day5_ending_true_22": {
        "name": "",
        "text": "*무릎을 꿇었다. 울었다. 12번 분의 눈물이 한꺼번에. ...유나가 다가와 등을 감싸 안아주었다. 차가운 새벽 공기 속에서 유나의 체온만이 유일한 현실 같았다.*"
    },
    "day5_ending_true_23": {
        "name": "최유나",
        "text": "\"...괜찮아요, 선배.\""
    },
    "day5_ending_true_24": {
        "name": "",
        "text": "*유나가 동터오는 하늘을, 학교의 울타리 너머를 바라보며 작게 속삭였다.*"
    },
    "day5_ending_true_25": {
        "name": "최유나",
        "text": "\"...이제 진짜, 졸업이에요.\""
    },
    "day5_ending_true_26": {
        "name": "",
        "text": "*뉴스 기사. '○○고등학교 비인가 연구시설 적발 — 불법 약물 투여 및 인체 임상시험 의혹'*"
    },
    "day5_ending_true_27": {
        "name": "",
        "text": "*'피해자 다수 기억장애 호소... 연구 책임자 B씨 구속' '3년간 재학하며 증거를 수집한 학생 C양의 제보가 결정적 역할'*"
    },
    "day5_ending_true_28": {
        "name": "",
        "text": "*핸드폰을 내려놓았다. 창밖. 새로운 학교. 새로운 교실. 아무도 모르는 곳.*"
    },
    "day5_ending_true_29": {
        "name": "",
        "text": "*이름표를 봤다. 내 이름. ...13번째 이름이 아니라, 처음의 이름.*"
    },
    "day5_ending_true_30": {
        "name": "",
        "text": "*...기억한다. 전부. 12명의 나를. 설화를. 은수를. 리인을. 세아를. 유나를.*"
    },
    "day5_ending_true_31": {
        "name": "",
        "text": "*왼손으로 연필을 잡았다. 7번째의 버릇. 설화의 버릇. — 내 버릇.*"
    },
    "day5_ending_true_32": {
        "name": "",
        "text": ""
    },
    "day5_ending_true_subtitle": {
        "name": "",
        "text": "졸업 ─ 졸업하지 못한 교실에서, 마침내."
    },
    "day5_ending_true_title": {
        "name": "",
        "text": ""
    },

    "day5_postcredit_1": {
        "name": "",
        "text": "*...어딘가에서 전화벨이 울린다.*"
    },
    "day5_postcredit_2": {
        "name": "",
        "text": "*넓은 사무실. 서류가 쌓인 책상. 모니터 여러 대. 화면에 학교 평면도가 떠 있다.*"
    },
    "day5_postcredit_3": {
        "name": "???",
        "text": "\"네. ...확인했습니다. 해당 거점은 폐쇄 처리하겠습니다. 자산 회수는 완료됐고, 인력은 재배치합니다.\""
    },
    "day5_postcredit_4": {
        "name": "???",
        "text": "\"13번 피험자 건으로 언론이 시끄러운데, 규정대로 현장 책임자 선에서 개인의 일탈로 덮습니다. 재단과의 연결 고리는 모두 파기하세요.\""
    },
    "day5_postcredit_5": {
        "name": "???",
        "text": "\"...네. 차기 시범 학교 선정은 끝났습니다.\""
    },
    "day5_postcredit_6": {
        "name": "???",
        "text": "\"교직원 재배치 기안은 올렸고요?\""
    },
    "day5_postcredit_7": {
        "name": "",
        "text": "*모니터 화면이 바뀐다. 새 학교의 사진. 새 교복. 새 이름들. 파일 제목이 보인다. '부적응 학생 교정 프로그램 ─ 2차 년도 시행 계획안'.*"
    },
    "day5_postcredit_8": {
        "name": "",
        "text": "*...새로운 전학생 프로필이 화면에 뜬다. 사진 속 학생이 웃고 있다. 아무것도 모르는 얼굴로.*"
    },
    "day5_postcredit_end": {
        "name": "",
        "text": ""
    },

    "day5_ending_escape_1": {
        "name": "",
        "text": "*달렸다. 유나와 함께. 학교를 빠져나왔다.*"
    },
    "day5_ending_escape_2": {
        "name": "",
        "text": "*뒤를 돌아봤다. 아무도 쫓아오지 않는다.*"
    },
    "day5_ending_escape_3": {
        "name": "",
        "text": "*...도망쳤다. 성공했다.*"
    },
    "day5_ending_escape_4": {
        "name": "최유나",
        "text": "\"...선배, 증거가 부족해요. 카메라에 사진은 있지만 문서는...\""
    },
    "day5_ending_escape_5": {
        "name": "나",
        "text": "\"...그래도 나왔잖아.\""
    },
    "day5_ending_escape_6": {
        "name": "",
        "text": "*걸었다. 새벽 도로. 가로등 아래.*"
    },
    "day5_ending_escape_7": {
        "name": "",
        "text": "*...머릿속이 조용하다. 기억이 돌아오지 않는다. 설화가 없으니까. 설화와 합쳐지지 못했으니까.*"
    },
    "day5_ending_escape_8": {
        "name": "",
        "text": "*12번의 기억은 — 학교 안에 남아있다.*"
    },
    "day5_ending_escape_9": {
        "name": "최유나",
        "text": "\"...선배. 왼손잡이였어요?\""
    },
    "day5_ending_escape_10": {
        "name": "나",
        "text": "\"...아니? 오른손잡이인데.\""
    },
    "day5_ending_escape_11": {
        "name": "",
        "text": "*유나가 입술을 깨문다. 뭔가 말하려다 삼킨다.*"
    },
    "day5_ending_escape_12": {
        "name": "",
        "text": "*...왼손으로 가방 끈을 쥐고 있었다. 무의식적으로.*"
    },
    "day5_ending_escape_subtitle": {
        "name": "",
        "text": "도주 ─ 기억 없는 탈출."
    },
    "day5_ending_escape_title": {
        "name": "",
        "text": ""
    },

    "day5_ending_resist_1": {
        "name": "박은수",
        "text": "\"...같이?\""
    },
    "day5_ending_resist_2": {
        "name": "나",
        "text": "\"선생님도 피해자예요. 이사회에 이용당한 거잖아요.\""
    },
    "day5_ending_resist_3": {
        "name": "박은수",
        "text": "\"......\""
    },
    "day5_ending_resist_4": {
        "name": "박은수",
        "text": "\"아니야. 3번째부터는 내 선택이었어.\""
    },
    "day5_ending_resist_5": {
        "name": "박은수",
        "text": "\"나는 가해자야, {name}.\""
    },
    "day5_ending_resist_6": {
        "name": "나",
        "text": "\"그래도. 여기 남으면 14번째가 시작돼요. 다른 사람한테.\""
    },
    "day5_ending_resist_7": {
        "name": "",
        "text": "*은수 선생님이 멈췄다. 설화가 나타났다. 은수 선생님 뒤에.*"
    },
    "day5_ending_resist_8": {
        "name": "설화",
        "text": "\"...은수.\""
    },
    "day5_ending_resist_9": {
        "name": "",
        "text": "*은수 선생님이 몸을 돌렸다. 설화를 봤다.*"
    },
    "day5_ending_resist_10": {
        "name": "박은수",
        "text": "\"...이설화.\""
    },
    "day5_ending_resist_11": {
        "name": "설화",
        "text": "\"6년 동안 매일 봤어. 선생님이 매번 새로운 나를 맞이하는 거.\""
    },
    "day5_ending_resist_12": {
        "name": "설화",
        "text": "\"매번 웃으면서. 매번 — 조금씩 부서지면서.\""
    },
    "day5_ending_resist_13": {
        "name": "설화",
        "text": "\"...선생님도 나가야 해.\""
    },
    "day5_ending_resist_14": {
        "name": "",
        "text": "*은수 선생님이 주사기를 바닥에 놓았다. ...한참을 서있었다.*"
    },
    "day5_ending_resist_15": {
        "name": "박은수",
        "text": "\"...밖에 나가면 내가 한 일 전부 들통나.\""
    },
    "day5_ending_resist_16": {
        "name": "나",
        "text": "\"알아요.\""
    },
    "day5_ending_resist_17": {
        "name": "박은수",
        "text": "\"감옥에 갈 수도 있어.\""
    },
    "day5_ending_resist_18": {
        "name": "나",
        "text": "\"알아요.\""
    },
    "day5_ending_resist_19": {
        "name": "",
        "text": "*은수 선생님이 — 울었다. 12번의 무게가 무너지듯.*"
    },
    "day5_ending_resist_20": {
        "name": "박은수",
        "text": "\"...어떻게 나를 데려가겠다는 거야. 너한테 이런 짓을 해놓고.\""
    },
    "day5_ending_resist_21": {
        "name": "나",
        "text": "\"...벌은 받아야 해요. 하지만 여기서 반복하는 것보다는.\""
    },
    "day5_ending_resist_22": {
        "name": "",
        "text": "*비상구를 지났다. 은수 선생님과 함께. 설화가 문 안에서 웃었다. 빛이 흩어졌다.*"
    },
    "day5_ending_resist_subtitle": {
        "name": "",
        "text": "반항 ─ 순환을 끊다."
    },
    "day5_ending_resist_title": {
        "name": "",
        "text": ""
    },

    "day5_ending_cage_eunsu_1": {
        "name": "박은수",
        "text": "\"...진짜?\""
    },
    "day5_ending_cage_eunsu_2": {
        "name": "나",
        "text": "\"...네.\""
    },
    "day5_ending_cage_eunsu_3": {
        "name": "",
        "text": "*선생님이 웃었다. 진심으로. 12번 동안 처음으로 — 기다리지 않아도 되는 미소.*"
    },
    "day5_ending_cage_eunsu_4": {
        "name": "박은수",
        "text": "\"...고마워, {name}.\""
    },
    "day5_ending_cage_eunsu_5": {
        "name": "",
        "text": "*선생님이 나를 안았다.*"
    },
    "day5_ending_cage_eunsu_6": {
        "name": "",
        "text": "*...교실. 오후의 햇살. 은수 선생님이 수업을 하고 있다. 나는 창가 자리에 앉아있다.*"
    },
    "day5_ending_cage_eunsu_7": {
        "name": "",
        "text": "*매일 같은 수업. 매일 같은 교실. 매일 같은 미소.*"
    },
    "day5_ending_cage_eunsu_8": {
        "name": "",
        "text": "***행복한가? ...행복해야 하는 건가?***"
    },
    "day5_ending_cage_eunsu_9": {
        "name": "",
        "text": "*창밖을 봤다. 울타리 너머 도로. 차가 지나간다.*"
    },
    "day5_ending_cage_eunsu_10": {
        "name": "",
        "text": "*...문은 열려있다. 언제든 나갈 수 있다.*"
    },
    "day5_ending_cage_eunsu_11": {
        "name": "",
        "text": "***나가지 않는다. 나가지 못하는 게 아니라 — 나가지 않는다.***"
    },

    "day5_ending_cage_sea_1": {
        "name": "",
        "text": "*세아가 나를 안았다. 복도에서.*"
    },
    "day5_ending_cage_sea_2": {
        "name": "한세아",
        "text": "\"...고마워.\""
    },
    "day5_ending_cage_sea_3": {
        "name": "한세아",
        "text": "\"이번에는 — 안 보내줘도 되는 거지?\""
    },
    "day5_ending_cage_sea_4": {
        "name": "",
        "text": "*고개를 끄덕였다. 세아가 울었다. 안도의 눈물.*"
    },
    "day5_ending_cage_sea_5": {
        "name": "",
        "text": ""
    },
    "day5_ending_cage_sea_6": {
        "name": "",
        "text": "*...학생회실. 세아가 도시락을 열었다. 나를 보고 웃는다.*"
    },
    "day5_ending_cage_sea_7": {
        "name": "",
        "text": "*...13번째. 아니, 세아에게는 첫 번째. 처음으로 보내주지 않아도 된 — 유일한 반복.*"
    },
    "day5_ending_cage_sea_8": {
        "name": "",
        "text": "***하지만 유나는 지하실에 있다. 그리고 나는 여전히 — 존재하지 않는 설화의 목소리를 듣고 있다.***"
    },
    "day5_ending_cage_sea_9": {
        "name": "",
        "text": "***그리고 내 기억은 — 언젠가 다시 지워질 것이다.***"
    },

    "day5_ending_cage_subtitle": {
        "name": "",
        "text": "새장 ─ 영원한 학교생활."
    },
    "day5_ending_cage_title": {
        "name": "",
        "text": ""
    },

    "day5_ending_forget_1": {
        "name": "나",
        "text": "\"...지워주세요.\""
    },
    "day5_ending_forget_2": {
        "name": "",
        "text": "*은수 선생님이 멈췄다.*"
    },
    "day5_ending_forget_3": {
        "name": "박은수",
        "text": "\"...진심이야?\""
    },
    "day5_ending_forget_4": {
        "name": "나",
        "text": "\"...이게 다 내 기억이라면... 저 지하실에 이름도 없이 버려진 12개의 줄이 전부 나라는 거잖아요.\""
    },
    "day5_ending_forget_5": {
        "name": "나",
        "text": "\"못 해요... 나 이거 감당 못 해. 머리가 터져버릴 것 같아...\""
    },
    "day5_ending_forget_6": {
        "name": "나",
        "text": "\"제발 지워주세요. 다 잊게 해주세요.\""
    },
    "day5_ending_forget_7": {
        "name": "",
        "text": "*은수 선생님이 주사기를 들었다. 손이 떨린다.*"
    },
    "day5_ending_forget_8": {
        "name": "박은수",
        "text": "\"...미안해.\""
    },
    "day5_ending_forget_9": {
        "name": "",
        "text": "*팔에 바늘이 들어왔다. 차갑다. 의식이 흐려진다.*"
    },
    "day5_ending_forget_10": {
        "name": "",
        "text": "*마지막으로 본 것 — 설화. 설화가 울고 있다. 입이 움직인다. 소리가 안 들린다.*"
    },
    "day5_ending_forget_11": {
        "name": "",
        "text": "*...읽을 수 있다. 입술의 움직임.*"
    },
    "day5_ending_forget_12": {
        "name": "",
        "text": "***\"잊지 마\"***"
    },
    "day5_ending_forget_13": {
        "name": "",
        "text": "*잊었다.*"
    },
    "day5_ending_forget_14": {
        "name": "",
        "text": "*...밝다. 알람이 울린다. 핸드폰을 봤다.*"
    },
    "day5_ending_forget_15": {
        "name": "",
        "text": "*'좋은 아침이에요, {new_name}!'*"
    },
    "day5_ending_forget_16": {
        "name": "",
        "text": "*이름이 다르다. 거울을 봤다. ...누구지? 나인데. 나 맞는데.*"
    },
    "day5_ending_forget_17": {
        "name": "",
        "text": "*...왜 눈물이 나지?*"
    },
    "day5_ending_forget_18": {
        "name": "",
        "text": "*학교에 가야 한다. 새 학교.*"
    },
    "day5_ending_forget_19": {
        "name": "",
        "text": "*교문에 선생님이 서 있다.*"
    },
    "day5_ending_forget_20": {
        "name": "박은수",
        "text": "\"어서 와. 너가 {new_name}이지? 전학 온 학생?\""
    },
    "day5_ending_forget_21": {
        "name": "박은수",
        "text": "\"선생님이 잘 돌봐줄게.\""
    },
    "day5_ending_forget_22": {
        "name": "",
        "text": "*선생님이 웃었다. 따뜻하게. ...어딘가에서 본 것 같은 미소.*"
    },

    "day5_ending_forget_sea_branch": {
        "name": "",
        "text": ""
    },
    "day5_ending_forget_sea_1": {
        "name": "",
        "text": "*교문 앞에 여학생이 서 있다. 밝은 미소. 반장 완장.*"
    },
    "day5_ending_forget_sea_2": {
        "name": "한세아",
        "text": "\"안녕! 오늘 전학 온 학생이지? 내가 안내해줄게.\""
    },
    "day5_ending_forget_sea_3": {
        "name": "",
        "text": "*...이 사람, 어디서 본 것 같은데. 어디서였지? ...기억나지 않는다.*"
    },
    "day5_ending_forget_subtitle": {
        "name": "",
        "text": "망각 ─ 14번째가 시작된다."
    },
    "day5_ending_forget_title": {
        "name": "",
        "text": ""
    },

    "day5_ending_ghost_1": {
        "name": "",
        "text": "*움직일 수 없다. 몸이 굳었다.*"
    },
    "day5_ending_ghost_2": {
        "name": "",
        "text": "*은수 선생님이 다가온다. 주사기를 들고.*"
    },
    "day5_ending_ghost_3": {
        "name": "",
        "text": "*...설화가 나타났다. 나와 은수 선생님 사이에.*"
    },
    "day5_ending_ghost_4": {
        "name": "설화",
        "text": "\"...내가 할게.\""
    },
    "day5_ending_ghost_5": {
        "name": "나",
        "text": "\"설화—?\""
    },
    "day5_ending_ghost_6": {
        "name": "설화",
        "text": "\"6번 동안 봤어. 네가 결정하지 못하는 걸.\""
    },
    "day5_ending_ghost_7": {
        "name": "설화",
        "text": "\"이번에도 못 하는 거지. 알아. 습관이니까.\""
    },
    "day5_ending_ghost_8": {
        "name": "설화",
        "text": "\"그러니까 — **내가 결정해줄게.**\""
    },
    "day5_ending_ghost_9": {
        "name": "",
        "text": "*설화가 나를 똑바로 봤다. 환각인데 — 이렇게까지 또렷한 건 처음이다.*"
    },
    "day5_ending_ghost_10": {
        "name": "설화",
        "text": "\"**달려. 지금.**\""
    },
    "day5_ending_ghost_11": {
        "name": "",
        "text": "*몸이 움직였다. 설화의 목소리가 — 내 안의 기억이 — 몸을 움직인다.*"
    },
    "day5_ending_ghost_12": {
        "name": "",
        "text": "*유나의 손을 잡고 비상구로 뛰었다. 은수 선생님이 뒤에서 외쳤지만 멈추지 않았다.*"
    },
    "day5_ending_ghost_13": {
        "name": "",
        "text": "*비상구를 나섰다. 뒤를 돌아봤다. 설화가 문 안쪽에 서 있다. 웃고 있다.*"
    },
    "day5_ending_ghost_14": {
        "name": "설화",
        "text": "\"...은수. 14번째는 없어.\""
    },
    "day5_ending_ghost_15": {
        "name": "",
        "text": "*설화가 사라졌다. 빛처럼. 소리 없이. 동시에 — 건물 안에서 경보가 울렸다. 건물이 소란스러워졌다. 사이렌, 발소리, 고함.*"
    },
    "day5_ending_ghost_16": {
        "name": "",
        "text": "*...설화가 없다. 머릿속에서도 — 아무 소리도 들리지 않는다. 학교를 빠져나왔다. 뒤에서 사이렌 소리가 울린다.*"
    },
    "day5_ending_ghost_17": {
        "name": "",
        "text": "*...새로운 곳. 새로운 생활. 기억은 돌아오지 않았다. 설화의 기억과 온전히 마주하지 못했으니까.*"
    },
    "day5_ending_ghost_18": {
        "name": "",
        "text": "*하지만— 가끔 밤에. 거울을 보면. ...은백색 머리카락이 보이는 것 같다. 찰나의 순간에.*"
    },
    "day5_ending_ghost_19": {
        "name": "",
        "text": "*왼손으로 연필을 집을 때. 복도에서 왼쪽으로 돌 때. 누군가의 이름을 부르려다 멈출 때.*"
    },
    "day5_ending_ghost_20": {
        "name": "",
        "text": "*...설화가 남긴 흔적. 1년 전에 폐기된 소녀가 남긴, 지울 수 없는 잔상.*"
    },
    "day5_ending_ghost_21": {
        "name": "",
        "text": "*몸이 기억하고 있다. 기억은 지워져도 — 그 애와 함께한 습관은 남아있다.*"
    },
    "day5_ending_ghost_subtitle": {
        "name": "",
        "text": "잔상 ─ 지울 수 없는 흔적."
    },
    "day5_ending_ghost_title": {
        "name": "",
        "text": ""
    },

    "day5_ending_complicit_1": {
        "name": "",
        "text": "*은수 선생님이 종이를 내밀었다.*"
    },
    "day5_ending_complicit_2": {
        "name": "박은수",
        "text": "\"네가 14번째 담당자가 되면 — 다시는 기억을 안 지워도 돼.\""
    },
    "day5_ending_complicit_3": {
        "name": "박은수",
        "text": "\"여기 남아. 선생님 옆에서. **같이** 돌봐주자.\""
    },
    "day5_ending_complicit_4": {
        "name": "나",
        "text": "\"...\""
    },
    "day5_ending_complicit_5": {
        "name": "",
        "text": "*종이를 봤다. '프로젝트 네버그라드 — 보조 연구원 계약서'.*"
    },
    "day5_ending_complicit_6": {
        "name": "나",
        "text": "\"...14번째가 오면 — 나도 그 아이한테 '어서 와, 선생님이 잘 돌봐줄게' 하는 거예요?\""
    },
    "day5_ending_complicit_7": {
        "name": "박은수",
        "text": "\"...그래.\""
    },
    "day5_ending_complicit_8": {
        "name": "",
        "text": "*계약서에 손을 올렸다.*"
    },
    "day5_ending_complicit_9": {
        "name": "",
        "text": "*...서명했다.*"
    },
    "day5_ending_complicit_10": {
        "name": "",
        "text": "*은수 선생님이 웃었다. 세아도 웃었다.*"
    },
    "day5_ending_complicit_11": {
        "name": "",
        "text": "***나도 웃었다.***"
    },
    "day5_ending_complicit_12": {
        "name": "",
        "text": "*교문. 아침. 새로운 학생이 걸어온다. 14번째.*"
    },
    "day5_ending_complicit_13": {
        "name": "",
        "text": "*...같은 얼굴. 다른 머리색. 다른 이름.*"
    },
    "day5_ending_complicit_14": {
        "name": "나",
        "text": "\"어서 와. 네가 {14th_name}이지?\""
    },
    "day5_ending_complicit_15": {
        "name": "",
        "text": "*14번째가 고개를 끄덕인다. 긴장한 표정.*"
    },
    "day5_ending_complicit_16": {
        "name": "나",
        "text": "\"걱정 마. 여기 좋은 사람들이 많아.\""
    },
    "day5_ending_complicit_17": {
        "name": "",
        "text": "***뒤에서 은수 선생님이 지켜보고 있다. ...설화가 복도 끝에서 나를 보고 있다. 울고 있다.***"
    },
    "day5_ending_complicit_18": {
        "name": "",
        "text": "***나는 웃었다.***"
    },
    "day5_ending_complicit_subtitle": {
        "name": "",
        "text": "공범 ─ 졸업시키지 않는 교실."
    },
    "day5_ending_complicit_title": {
        "name": "",
        "text": ""
    },

    "day5_cage_loop": {
        "name": "",
        "text": ""
    }
}
